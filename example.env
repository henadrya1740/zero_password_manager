# Zero Vault - Example Environment Configuration
# Copy this file to .env and fill in the values

# --- MANDATORY SECURITY KEYS ---
# JWT Secret: REQUIRED. Minimum 64 characters for maximum entropy.
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# Key for encrypting seed phrases in the database. REQUIRED.
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(64))"
SEED_PHRASE_KEY=

# Base64 encoded master key for TOTP encryption. REQUIRED.
# Format: 32-byte key encoded to Base64
TOTP_MASTER_KEY=

# Secret for device fingerprinting HMAC. REQUIRED.
DEVICE_SECRET=


# --- SERVER SETTINGS ---
ENVIRONMENT=development
PORT=3000
DATABASE_URL=sqlite:///./zero_vault.db


# --- AUTH & SESSIONS ---
PERMISSIONS_OTP_LIST=login,vault_write
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30


# --- SECURITY POLICY ---
MAX_FAILED_OTP_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15
BLOCK_CLEANUSE_INTERVAL_HOURS=1
MAX_PASSWORDS_PER_USER=1000


# --- EXTERNAL INTEGRATIONS ---
# Bot Token for Telegram Security Alerts (Optional in dev, recommended in prod)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# --- WEBAUTHN / FIDO2 ---
RP_ID=localhost
RP_NAME=Zero Password Manager
EXPECTED_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
