# --- Zero Vault API Configuration ---

# Security settings
# Generate a secure key: openssl rand -hex 32
JWT_SECRET_KEY=your_very_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Configuration
# Comma-separated list of actions that require 2FA OTP verification
# Options: login, vault_read, vault_write, audit_read
# Example: PERMISSIONS_OTP_LIST=login,vault_read,audit_read
PERMISSIONS_OTP_LIST=login
