# --- Zero Vault API Configuration ---

# ── Security (REQUIRED) ───────────────────────────────────────────────────────

# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# The server WILL NOT START if this is missing or uses the insecure default.
JWT_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS

# NOTE: ALGORITHM is intentionally hardcoded to HS256 in code and cannot be
# overridden via env — this prevents the "alg:none" JWT bypass attack.

# ── CORS (REQUIRED for browser clients) ──────────────────────────────────────
# Comma-separated list of allowed origins (no wildcards).
# Example: ALLOWED_ORIGINS=http://192.168.1.100:8080,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080

# ── Token expiry ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OTP / 2FA gating ─────────────────────────────────────────────────────────
# Comma-separated list of actions that require 2FA OTP verification.
# Options: login, vault_read, vault_write, audit_read
PERMISSIONS_OTP_LIST=login
